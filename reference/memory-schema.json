{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoirRiver Memory Collection",
  "description": "回忆录数据结构定义 - 用于记忆河流网站生成",
  "type": "object",
  "required": ["subject", "memories"],
  "properties": {
    "subject": {
      "type": "object",
      "description": "回忆者基本信息",
      "required": ["name", "birthYear"],
      "properties": {
        "name": { "type": "string", "description": "回忆者姓名" },
        "birthYear": { "type": "integer", "description": "出生年份" },
        "birthPlace": { "type": "string", "description": "出生地" },
        "avatar": { "type": "string", "description": "头像图片路径（可选）" },
        "motto": { "type": "string", "description": "座右铭或人生信条（可选）" }
      }
    },
    "memories": {
      "type": "array",
      "description": "记忆片段集合",
      "items": {
        "type": "object",
        "required": ["id", "date", "title", "content"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^mem_\\d{3,}$",
            "description": "唯一标识，格式 mem_001"
          },
          "date": {
            "type": "object",
            "required": ["year"],
            "properties": {
              "year": { "type": "integer", "description": "年份" },
              "month": { "type": ["integer", "null"], "minimum": 1, "maximum": 12 },
              "day": { "type": ["integer", "null"], "minimum": 1, "maximum": 31 },
              "approximate": { "type": "boolean", "description": "日期是否为大约" }
            }
          },
          "title": {
            "type": "string",
            "maxLength": 30,
            "description": "一句话摘要（不超过20-30字，有画面感）"
          },
          "content": {
            "type": "string",
            "description": "整理后的完整文本"
          },
          "rawTranscript": {
            "type": "string",
            "description": "原始转写文本"
          },
          "audioFile": {
            "type": "string",
            "description": "原始音频文件路径（相对于 memoir/ 目录）"
          },
          "audioSnippet": {
            "type": "object",
            "description": "音频精华片段的时间范围（秒）",
            "properties": {
              "start": { "type": "number", "minimum": 0 },
              "end": { "type": "number", "minimum": 0 },
              "snippetFile": { "type": "string", "description": "裁剪后的片段文件路径" }
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "标签（如：童年、食物、工作、家庭）"
          },
          "newsAnchor": {
            "type": "string",
            "description": "关联的历史新闻事件"
          },
          "mood": {
            "type": "string",
            "enum": ["温暖", "欢乐", "平静", "感伤", "激动", "骄傲", "思念", "释然"],
            "description": "记忆的情绪色彩"
          },
          "location": {
            "type": "string",
            "description": "记忆发生的地点"
          },
          "people": {
            "type": "array",
            "items": { "type": "string" },
            "description": "记忆中涉及的人物"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "项目元数据",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "totalSessions": { "type": "integer", "description": "总对话次数" },
        "totalDuration": { "type": "string", "description": "总录音时长" }
      }
    }
  }
}
